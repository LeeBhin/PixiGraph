{
  "name": "@leebhin/pixigraph",
  "version": "0.3.1",
  "description": "Pixi.js 기반 그래프 렌더링 라이브러리 — node/edge/highlight/preview/history/viewport (cytoscape-like API)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "pixi.js": "^8.18.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LeeBhin/PixiGraph.git"
  },
  "keywords": [
    "pixi",
    "pixijs",
    "graph",
    "rendering",
    "cytoscape",
    "webgl"
  ],
  "license": "MIT"
}
