{
  "name": "pixigraph",
  "version": "0.1.0",
  "description": "Pixi.js 기반 그래프 렌더링 라이브러리 — node/edge/highlight/preview/history (cytoscape-like API)",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "pixi.js": "^8.18.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "pixi",
    "pixijs",
    "graph",
    "rendering",
    "cytoscape",
    "webgl"
  ],
  "license": "MIT"
}
